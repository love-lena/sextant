{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "target": "es2023",
    "lib": ["es2023"],
    "types": ["node"],
    "strict": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["extension.ts", "spike.ts", "busharness.ts"]
}
