{
  "name": "@sextant/client",
  "version": "0.1.0",
  "description": "TypeScript client for the sextant bus — mirrors pkg/client (Go).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "codegen": "tsx scripts/codegen.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "nats": "2.29.3",
    "smol-toml": "1.6.1"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "json-schema-to-typescript": "15.0.4",
    "tsx": "4.22.3",
    "typescript": "5.6.3",
    "vitest": "4.1.7"
  }
}
