{
  "name": "@sextant/sidecar",
  "version": "0.1.0",
  "description": "Sextant sidecar runtime — runs inside the per-agent container, bridges the Claude Code Agent SDK to the sextant bus. Plan: plans/bootstrap.md#M9",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "sextant-sidecar": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node ./dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.150",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@sextant/client": "file:../client-ts"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "typescript": "5.6.3"
  }
}
