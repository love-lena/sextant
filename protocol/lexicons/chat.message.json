{
  "lexicon": 1,
  "id": "chat.message",
  "defs": {
    "main": {
      "type": "record",
      "description": "A line of dialogue on a topic or direct address. The author is the frame author.",
      "record": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "Message text."
          },
          "replyTo": {
            "type": "string",
            "description": "Optional frame id this message replies to."
          }
        }
      }
    }
  }
}
