# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*.swo
*~

# Go
*.test
*.out
/bin/
/dist/

# Node / TypeScript
node_modules/
*.tsbuildinfo

# mdbook build output (the rendered site; src/ is canon)
/docs/book/book/

# Embedded-bus store: JetStream data + operator/account/user key material
# (default `sextant up --store` location). Never commit keys.
/.sextant/

# Ephemeral plane (ADR-0002): the agent workspace — specs, work-plans,
# breakdowns. Never committed; committed ⇔ signed-off.
/.work/

# Agent skills: the engineering skill bodies are COMMITTED under .claude/skills/
# so a fresh clone has them with no install step. Ignore everything else under
# .claude/, the other agents' skill copies, and the superpowers cache.
/.claude/*
!/.claude/skills/
/.agents/
/.superpowers/

# VHS renders an mp4 alongside the gif; only the gif is committed
docs/demos/*.mp4

# stray build output of `go build ./cmd/sextant` from the repo root
/sextant

# Generated dash UI bundles (TASK-121): the *.js are transpiled from *.jsx by
# scripts/build-dash-ui.sh at build time (make ui / go:generate / CI / release),
# never committed. image-slot.js is hand-written source and vendor/*.min.js is
# vendored, so neither is ignored.
/internal/dashapi/web/app/app.js
/internal/dashapi/web/app/artifact.js
/internal/dashapi/web/app/home.js
/internal/dashapi/web/app/sidebar.js
/internal/dashapi/web/app/tweaks-panel.js
