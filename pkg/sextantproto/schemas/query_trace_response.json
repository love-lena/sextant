{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant-initial/pkg/sextantproto/query-trace-response",
  "$ref": "#/$defs/QueryTraceResponse",
  "$defs": {
    "QueryTraceResponse": {
      "properties": {
        "spans": {
          "items": {
            "$ref": "#/$defs/TraceSpan"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "spans"
      ]
    },
    "TraceSpan": {
      "properties": {
        "trace_id": {
          "type": "string"
        },
        "span_id": {
          "type": "string"
        },
        "parent_span_id": {
          "type": "string"
        },
        "span_name": {
          "type": "string"
        },
        "span_kind": {
          "type": "string"
        },
        "service_name": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "duration_nanos": {
          "type": "integer"
        },
        "status_code": {
          "type": "string"
        },
        "status_message": {
          "type": "string"
        },
        "attributes": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "trace_id",
        "span_id",
        "span_name",
        "span_kind",
        "service_name",
        "timestamp",
        "duration_nanos"
      ]
    }
  }
}
