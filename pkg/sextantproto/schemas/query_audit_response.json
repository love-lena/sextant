{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/query-audit-response",
  "$ref": "#/$defs/QueryAuditResponse",
  "$defs": {
    "QueryAuditResponse": {
      "properties": {
        "rows": {
          "items": {
            "$ref": "#/$defs/QueryAuditRow"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "rows"
      ]
    },
    "QueryAuditRow": {
      "properties": {
        "id": {
          "$ref": "#/$defs/UUID"
        },
        "ts": {
          "type": "string",
          "format": "date-time"
        },
        "actor": {
          "type": "string"
        },
        "agent_uuid": {
          "$ref": "#/$defs/UUID"
        },
        "action": {
          "type": "string"
        },
        "capability_required": {
          "type": "string"
        },
        "result": {
          "type": "string"
        },
        "payload": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "ts",
        "actor",
        "agent_uuid",
        "action",
        "capability_required",
        "result",
        "payload"
      ]
    },
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    }
  }
}
