{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/prompt-agent-request",
  "$ref": "#/$defs/PromptAgentRequest",
  "$defs": {
    "PromptAgentRequest": {
      "properties": {
        "agent_id": {
          "$ref": "#/$defs/UUID"
        },
        "content": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "agent_id",
        "content"
      ]
    },
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    }
  }
}
