{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/heartbeat-payload",
  "$ref": "#/$defs/HeartbeatPayload",
  "$defs": {
    "HeartbeatPayload": {
      "properties": {
        "agent_uuid": {
          "$ref": "#/$defs/UUID"
        },
        "incarnation_id": {
          "$ref": "#/$defs/UUID"
        },
        "host_id": {
          "type": "string"
        },
        "uptime_seconds": {
          "type": "integer"
        },
        "last_frame_ts": {
          "$ref": "#/$defs/Timestamp"
        },
        "pending_prompts": {
          "type": "integer"
        },
        "resource_usage": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "agent_uuid",
        "incarnation_id",
        "host_id",
        "uptime_seconds"
      ]
    },
    "Timestamp": {
      "properties": {},
      "additionalProperties": false,
      "type": "object"
    },
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    }
  }
}
