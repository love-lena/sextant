{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/query-history-request",
  "$ref": "#/$defs/QueryHistoryRequest",
  "$defs": {
    "QueryHistoryFilter": {
      "properties": {
        "subject": {
          "type": "string"
        },
        "from_id": {
          "type": "string"
        },
        "agent_uuid": {
          "$ref": "#/$defs/UUID"
        },
        "kind": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "QueryHistoryRequest": {
      "properties": {
        "filter": {
          "$ref": "#/$defs/QueryHistoryFilter"
        },
        "time_range": {
          "$ref": "#/$defs/TimeRange"
        },
        "limit": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "filter",
        "time_range"
      ]
    },
    "TimeRange": {
      "properties": {
        "since": {
          "type": "string",
          "format": "date-time"
        },
        "until": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    }
  }
}
