{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/list-dir-response",
  "$ref": "#/$defs/ListDirResponse",
  "$defs": {
    "ListDirEntry": {
      "properties": {
        "name": {
          "type": "string"
        },
        "is_dir": {
          "type": "boolean"
        },
        "size": {
          "type": "integer"
        },
        "mode": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "is_dir"
      ]
    },
    "ListDirResponse": {
      "properties": {
        "entries": {
          "items": {
            "$ref": "#/$defs/ListDirEntry"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "entries"
      ]
    }
  }
}
