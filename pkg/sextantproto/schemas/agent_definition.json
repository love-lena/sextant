{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/agent-definition",
  "$ref": "#/$defs/AgentDefinition",
  "$defs": {
    "AgentDefinition": {
      "properties": {
        "uuid": {
          "$ref": "#/$defs/UUID"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "spec": {
          "$ref": "#/$defs/AgentSpec"
        },
        "status": {
          "$ref": "#/$defs/AgentStatusRecord"
        },
        "version": {
          "type": "integer"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "escalate_to": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "uuid",
        "name",
        "type",
        "spec",
        "status",
        "version",
        "created_at",
        "updated_at"
      ]
    },
    "AgentSpec": {
      "properties": {
        "desired": {
          "type": "string"
        },
        "runtime": {
          "$ref": "#/$defs/RuntimeConfig"
        },
        "sandbox": {
          "$ref": "#/$defs/SandboxConfig"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "host_pin": {
          "type": "string"
        },
        "restart_policy": {
          "type": "string"
        },
        "grace_seconds": {
          "type": "integer"
        },
        "generation": {
          "type": "integer"
        },
        "reactuation_nonce": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "desired",
        "runtime",
        "sandbox",
        "generation",
        "reactuation_nonce"
      ]
    },
    "AgentStatusRecord": {
      "properties": {
        "observed": {
          "type": "string"
        },
        "phase": {
          "type": "string"
        },
        "current_incarnation_id": {
          "$ref": "#/$defs/UUID"
        },
        "observed_generation": {
          "type": "integer"
        },
        "observed_nonce": {
          "type": "integer"
        },
        "spec_fingerprint": {
          "type": "string"
        },
        "wire_epoch": {
          "type": "integer"
        },
        "restart_count": {
          "type": "integer"
        },
        "crash_window": {
          "$ref": "#/$defs/CrashWindow"
        },
        "last_exit": {
          "$ref": "#/$defs/LastExit"
        },
        "session_snapshot": {
          "type": "string"
        },
        "last_heartbeat_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "last_reconciled_at": {
          "$ref": "#/$defs/Timestamp"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "observed"
      ]
    },
    "CrashWindow": {
      "properties": {
        "count": {
          "type": "integer"
        },
        "since": {
          "$ref": "#/$defs/Timestamp"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "LastExit": {
      "properties": {
        "code": {
          "type": "integer"
        },
        "reason": {
          "type": "string"
        },
        "at": {
          "$ref": "#/$defs/Timestamp"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ResourceLimits": {
      "properties": {
        "cpu_shares": {
          "type": "integer"
        },
        "memory_mib": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "RuntimeConfig": {
      "properties": {
        "model": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "params": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "permission_mode": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "initial_prompt": {
          "type": "string"
        },
        "permission_ceiling": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "model"
      ]
    },
    "SandboxConfig": {
      "properties": {
        "image": {
          "type": "string"
        },
        "mounts": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "credentials": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "resource_limits": {
          "$ref": "#/$defs/ResourceLimits"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "image"
      ]
    },
    "Timestamp": {
      "properties": {},
      "additionalProperties": false,
      "type": "object"
    },
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    }
  }
}
