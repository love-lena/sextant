{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/worktree-info",
  "$ref": "#/$defs/WorktreeInfo",
  "$defs": {
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    },
    "WorktreeInfo": {
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "base_branch": {
          "type": "string"
        },
        "owning_agent": {
          "$ref": "#/$defs/UUID"
        },
        "status": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_activity": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "path",
        "branch",
        "base_branch",
        "status",
        "created_at",
        "last_activity"
      ]
    }
  }
}
