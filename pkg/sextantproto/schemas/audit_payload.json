{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/audit-payload",
  "$ref": "#/$defs/AuditPayload",
  "$defs": {
    "AuditPayload": {
      "properties": {
        "actor": {
          "type": "string"
        },
        "agent_uuid": {
          "$ref": "#/$defs/UUID"
        },
        "action": {
          "type": "string"
        },
        "capability_required": {
          "type": "string"
        },
        "result": {
          "type": "string"
        },
        "details": {
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "actor",
        "action",
        "result"
      ]
    },
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    }
  }
}
