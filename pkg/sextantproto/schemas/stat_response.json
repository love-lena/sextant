{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/stat-response",
  "$ref": "#/$defs/StatResponse",
  "$defs": {
    "StatResponse": {
      "properties": {
        "name": {
          "type": "string"
        },
        "size": {
          "type": "integer"
        },
        "mode": {
          "type": "string"
        },
        "is_dir": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "size",
        "mode",
        "is_dir"
      ]
    }
  }
}
