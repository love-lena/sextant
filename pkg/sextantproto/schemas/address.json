{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant-initial/pkg/sextantproto/address",
  "$ref": "#/$defs/Address",
  "$defs": {
    "Address": {
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "host": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "kind",
        "id"
      ]
    }
  }
}
