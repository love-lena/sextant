{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant-initial/pkg/sextantproto/user-input-response-payload",
  "$ref": "#/$defs/UserInputResponsePayload",
  "$defs": {
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    },
    "UserInputResponsePayload": {
      "properties": {
        "request_id": {
          "$ref": "#/$defs/UUID"
        },
        "decision": {
          "type": "string"
        },
        "answer": {
          "type": "string"
        },
        "escalate_to": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "request_id",
        "decision"
      ]
    }
  }
}
