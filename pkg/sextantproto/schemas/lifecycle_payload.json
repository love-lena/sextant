{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant-initial/pkg/sextantproto/lifecycle-payload",
  "$ref": "#/$defs/LifecyclePayload",
  "$defs": {
    "LifecyclePayload": {
      "properties": {
        "incarnation_id": {
          "$ref": "#/$defs/UUID"
        },
        "agent_uuid": {
          "$ref": "#/$defs/UUID"
        },
        "transition": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "exit_code": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "incarnation_id",
        "agent_uuid",
        "transition",
        "state"
      ]
    },
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    }
  }
}
