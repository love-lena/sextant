{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/agent-frame-payload",
  "$ref": "#/$defs/AgentFramePayload",
  "$defs": {
    "AgentFramePayload": {
      "properties": {
        "frame_kind": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "tool_name": {
          "type": "string"
        },
        "body": {
          "type": "object"
        },
        "tokens": {
          "$ref": "#/$defs/FrameTokens"
        },
        "tags": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "frame_kind",
        "body"
      ]
    },
    "FrameTokens": {
      "properties": {
        "input": {
          "type": "integer"
        },
        "output": {
          "type": "integer"
        },
        "cache_read": {
          "type": "integer"
        },
        "cache_created": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "input",
        "output"
      ]
    }
  }
}
