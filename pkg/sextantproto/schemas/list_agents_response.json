{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant-initial/pkg/sextantproto/list-agents-response",
  "$ref": "#/$defs/ListAgentsResponse",
  "$defs": {
    "AgentSummary": {
      "properties": {
        "uuid": {
          "$ref": "#/$defs/UUID"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "lifecycle": {
          "type": "string"
        },
        "version": {
          "type": "integer"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "uuid",
        "name",
        "lifecycle",
        "version",
        "updated_at"
      ]
    },
    "ListAgentsResponse": {
      "properties": {
        "agents": {
          "items": {
            "$ref": "#/$defs/AgentSummary"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "agents"
      ]
    },
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    }
  }
}
