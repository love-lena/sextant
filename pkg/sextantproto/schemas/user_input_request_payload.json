{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/user-input-request-payload",
  "$ref": "#/$defs/UserInputRequestPayload",
  "$defs": {
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    },
    "UserInputRequestPayload": {
      "properties": {
        "request_id": {
          "$ref": "#/$defs/UUID"
        },
        "from_uuid": {
          "$ref": "#/$defs/UUID"
        },
        "question": {
          "type": "string"
        },
        "options": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "urgency": {
          "type": "string"
        },
        "group_with": {
          "$ref": "#/$defs/UUID"
        },
        "context": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "request_id",
        "from_uuid",
        "question"
      ]
    }
  }
}
