{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/read-file-response",
  "$ref": "#/$defs/ReadFileResponse",
  "$defs": {
    "ReadFileResponse": {
      "properties": {
        "content": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "content_type": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "content",
        "content_type"
      ]
    }
  }
}
