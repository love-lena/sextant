{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/get-agent-status-response",
  "$ref": "#/$defs/GetAgentStatusResponse",
  "$defs": {
    "AgentStatus": {
      "properties": {
        "uuid": {
          "$ref": "#/$defs/UUID"
        },
        "name": {
          "type": "string"
        },
        "lifecycle": {
          "type": "string"
        },
        "version": {
          "type": "integer"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "restarts": {
          "type": "integer"
        },
        "last_exit_reason": {
          "type": "string"
        },
        "heartbeat": {
          "$ref": "#/$defs/HeartbeatSnapshot"
        },
        "session_log": {
          "$ref": "#/$defs/SessionLogInfo"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "uuid",
        "name",
        "lifecycle",
        "version",
        "updated_at"
      ]
    },
    "GetAgentStatusResponse": {
      "properties": {
        "status": {
          "$ref": "#/$defs/AgentStatus"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "status"
      ]
    },
    "HeartbeatSnapshot": {
      "properties": {
        "last_seen": {
          "type": "string",
          "format": "date-time"
        },
        "age_seconds": {
          "type": "number"
        },
        "source": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "source"
      ]
    },
    "SessionLogInfo": {
      "properties": {
        "projects_dir": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    }
  }
}
