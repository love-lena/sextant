{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant-initial/pkg/sextantproto/kill-agent-request",
  "$ref": "#/$defs/KillAgentRequest",
  "$defs": {
    "KillAgentRequest": {
      "properties": {
        "agent_id": {
          "$ref": "#/$defs/UUID"
        },
        "grace_seconds": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "agent_id"
      ]
    },
    "UUID": {
      "items": {
        "type": "integer"
      },
      "type": "array",
      "maxItems": 16,
      "minItems": 16
    }
  }
}
