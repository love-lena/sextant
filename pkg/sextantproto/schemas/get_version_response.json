{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/love-lena/sextant/pkg/sextantproto/get-version-response",
  "$ref": "#/$defs/GetVersionResponse",
  "$defs": {
    "GetVersionResponse": {
      "properties": {
        "daemon_version": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        },
        "proto_version": {
          "type": "string"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "pid": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "daemon_version",
        "commit",
        "proto_version",
        "started_at",
        "pid"
      ]
    }
  }
}
